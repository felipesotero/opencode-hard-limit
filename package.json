{
  "name": "opencode-hard-limit",
  "version": "0.8.0",
  "description": "OpenCode plugin that hard-stops model calls before you burn through your AI quota. Monitors the 5h or weekly window for Claude and Codex, blocks at a configurable percent-remaining threshold, and shows a live usage bar in the sidebar. Set your goal per-project or globally via CLI or env.",
  "type": "module",
  "main": "quota-hard-stop.js",
  "scripts": {
    "test": "node --test"
  },
  "exports": {
    ".": "./quota-hard-stop.js",
    "./config": "./lib/config.js"
  },
  "bin": {
    "opencode-hard-limit": "bin/cli.js"
  },
  "files": [
    "quota-hard-stop.js",
    "quota-sidebar.tsx",
    "lib/config.js",
    "lib/quota.js",
    "lib/evaluate.js",
    "bin/cli.js",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.3"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "quota",
    "quota-monitoring",
    "monitoring",
    "limit",
    "hard-limit",
    "rate-limit",
    "rate-limiting",
    "usage",
    "usage-tracking",
    "budget",
    "cost-control",
    "guardrail",
    "throttle",
    "ai",
    "llm",
    "anthropic",
    "claude",
    "openai",
    "codex",
    "tui",
    "sidebar"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felipesotero/opencode-hard-limit.git"
  },
  "bugs": {
    "url": "https://github.com/felipesotero/opencode-hard-limit/issues"
  },
  "homepage": "https://github.com/felipesotero/opencode-hard-limit#readme",
  "license": "MIT",
  "peerDependencies": {
    "@slkiser/opencode-quota": ">=3 <4"
  },
  "peerDependenciesMeta": {
    "@slkiser/opencode-quota": {
      "optional": true
    }
  }
}
